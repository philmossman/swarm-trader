# AI Hedge Fund — Environment Variables
# Copy this to .env and fill in your keys.
# .env is gitignored and will NOT be committed.

# Alpaca Paper Trading (required for trade execution)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Financial data — free for AAPL, GOOGL, MSFT, NVDA, TSLA
# For other tickers, get a key from https://financialdatasets.ai/
FINANCIAL_DATASETS_API_KEY=

# LLM providers (only needed if NOT using Ollama)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
